# Router Emulator Environment Template (Copy to .env or cloudrun.env)

PORT=8080
LOG_LEVEL=INFO

# SNMP Agent Configuration
SNMP_ENABLED=true
SNMP_PORT=1161
SNMP_COMMUNITY=public

# Unique Router Attributes
ROUTER_ID=RTR-US-WEST-02
ROUTER_LOCATION=Seattle Edge POP, Cabinet 03
ROUTER_PURPOSE=BGP Border Peer Router
MANUFACTURER_ID=JUNIPER-MX960
FIRMWARE_VERSION=JUNOS-22.4R1

# Security & Command Authorization
CONTROL_PASSWORD=SecureRouterToken999!
CONTROL_HEADER=X-Control-Password
